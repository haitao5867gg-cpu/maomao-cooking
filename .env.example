# ===== 环境标识 =====
MAOMAO_ENV=dev                      # dev | staging | prod

# ===== LLM 网关（统一 OpenAI 兼容接口，换供应商改这三行）=====
LLM_PROVIDER=deepseek               # deepseek | azure_foundry | claude_subscription
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# ===== Azure（按环境使用对应资源组的连接串）=====
AZURE_STORAGE_CONNECTION_STRING=    # 队列 + 表 + Blob
AZURE_SPEECH_KEY=                   # 中文 TTS
AZURE_SPEECH_REGION=eastasia

# ===== B站上传（仅 prod 环境配置，dev/staging 留空）=====
BILIUP_COOKIE_PATH=                 # biliup 登录态文件路径，永不入 git

# ===== 告警 =====
ALERT_CHANNEL=bark                  # bark | telegram | none
ALERT_URL=                          # Bark 推送 URL 或 Telegram bot webhook

# ===== GPU worker（2070Ti 机器）=====
SD_WEBUI_URL=http://127.0.0.1:7860  # 本机 SD API 地址
CAT_LORA_NAME=maomao_v1             # 猫主角 LoRA
CAT_BASE_SEED=42                    # 固定 seed 保证角色一致性
